{
  "name": "web-empresarial-frontend",
  "version": "1.1.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "ng": "ng",
    "start": "node dist/web-empresarial-frontend/server/server.mjs",
    "build": "sed -i \"s/BUILD_TS: [0-9]\\+/BUILD_TS: $(date +%s)/\" src/environments/environment.prod.ts && ng build --configuration production --optimization=true --source-map=false --output-hashing=all --aot",
    "build:deploy": "ng build --configuration deploy --optimization=true --source-map=false  --output-hashing=all --aot",
    "build:staging": "ng build --configuration staging --optimization=true --source-map=false  --output-hashing=all --aot",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:web-empresarial-frontend": "node dist/web-empresarial-frontend/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.15",
    "@angular/platform-server": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@angular/ssr": "^21.2.13",
    "@emailjs/browser": "^4.4.1",
    "@jsverse/transloco": "^8.3.0",
    "embla-carousel": "^8.6.0",
    "express": "^4.22.2",
    "nodemailer": "^7.0.13",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "@types/express": "^4.17.25",
    "@types/jasmine": "~5.1.15",
    "@types/node": "^24.12.4",
    "autoprefixer": "^10.5.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3"
  }
}
